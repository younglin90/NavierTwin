{
  "name": "naviertwin-desktop",
  "version": "0.1.0",
  "description": "NavierTwin desktop shell (Electron) wrapping the trame web GUI",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "smoke": "electron . --smoke",
    "test": "node --test test/*.test.js",
    "pack": "electron-builder --dir",
    "dist:linux": "electron-builder --linux AppImage",
    "dist:win": "electron-builder --win nsis"
  },
  "author": "NavierTwin Contributors",
  "license": "MIT",
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "org.naviertwin.desktop",
    "productName": "NavierTwin",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "server-launch.js",
      "server-process.js",
      "splash.html",
      "assets/**/*",
      "package.json"
    ],
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "linux": {
      "target": ["AppImage"],
      "category": "Science",
      "icon": "assets/icon.png"
    },
    "win": {
      "target": ["nsis"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": false
    }
  }
}
